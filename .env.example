# Vercel Postgres connection string
POSTGRES_URL="postgres://user:password@host/database?sslmode=require"

# Admin password for Laila to log in
ADMIN_PASSWORD="kies-een-sterk-wachtwoord"

# Secret for signing JWT tokens (minimum 32 random characters)
JWT_SECRET="vervang-dit-door-een-willekeurige-string-van-minstens-32-tekens"

# Public URL of your site (no trailing slash)
NEXT_PUBLIC_SITE_URL="https://jouw-domein.vercel.app"

# One-time setup key to initialize the database tables
SETUP_KEY="setup-sleutel-alleen-eenmalig-gebruiken"

# Mollie API key for DIY scanner deposit payments
MOLLIE_API_KEY="test_xxxxxxxxxxxxxxxxxxxxxxxx"

# Anthropic API key for AI content ideas in social planner
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxx"

# WooCommerce REST API (voor auto-aanmaken kortingscodes/cadeaubonnen)
# Genereer in WP Admin: WooCommerce > Settings > Advanced > REST API > Add key
# Permissions: Read/Write
WOOCOMMERCE_URL="https://gravida.nl"
WOOCOMMERCE_KEY="ck_xxxxxxxxxxxxxxxxxxxxxxxx"
WOOCOMMERCE_SECRET="cs_xxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Atelier AI scans (smartphone app uploads) ────────────────────────────────
# Shared secret tussen dashboard.gravida.nl en de Gravida Scan app. De app stuurt
# 'm als X-Scan-App-Token header op de publieke /api/scan/* endpoints. Laat
# leeg in development om de check uit te zetten. In productie ALTIJD zetten.
SCAN_APP_TOKEN="kies-een-willekeurige-string-van-minstens-32-tekens"

# Waar de "nieuwe AI-scan binnen" notification heen gaat (optioneel,
# default = hi@gravida.nl).
ATELIER_INBOX_EMAIL="hi@gravida.nl"

# Vercel Blob storage. Genereer in Vercel dashboard > Storage > Blob.
# Vereist voor de AI scan foto-uploads en de bestaande media-library/CMS uploads.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Rodin (Hyperhuman by Deemos) auto-preview ──────────────────────────────
# Bearer-token van https://hyperhuman.deemos.com console. Nodig voor de
# automatische 3D-preview die de klant in-app ziet na het uploaden. Laat leeg
# om de auto-preview uit te zetten (scans landen dan direct in admin zonder
# preview-mesh).
RODIN_API_KEY="sk-rodin-xxxxxxxxxxxxxxxxxxxxxxxx"

# Optioneel, default = 'https://hyperhuman.deemos.com/api/v2'. Override alleen
# voor self-hosted of staging-Rodin.
# RODIN_API_BASE="https://hyperhuman.deemos.com/api/v2"

# ─── Vercel cron security ──────────────────────────────────────────────────
# Vercel signt cron-invocaties met deze secret als Bearer header. Voorkomt
# dat externe callers expensive cron endpoints triggeren (Rodin polling
# kost credits). Genereer als willekeurige 32+ char string.
CRON_SECRET="kies-een-willekeurige-string-van-minstens-32-tekens"

# Public URL van de Gravida Scan app (zonder trailing slash). Wordt gebruikt
# door /api/scan/[id]/deposit als Mollie redirectUrl. Default
# https://gravida-app.vercel.app als niet gezet.
NEXT_PUBLIC_SCAN_APP_URL="https://gravida-app.vercel.app"
